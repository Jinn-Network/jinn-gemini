# Jinn Worker Configuration
# An EOA is required to provision the agent's on-chain identity (Gnosis Safe).
# The bootstrap process is deterministic based on this key and the chain ID.
WORKER_PRIVATE_KEY=
CHAIN_ID=
RPC_URL=

# Supabase Configuration
# Required for job management and data persistence.
SUPABASE_URL=
SUPABASE_PROJECT_ID=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SERVICE_ANON_KEY=

# LLM API Configuration
GEMINI_API_KEY=
OPENAI_API_KEY=

# E2E Testing Configuration (Optional)
# These variables are required to run the end-to-end test suite.
# The test rig uses Tenderly to create ephemeral test environments.
TENDERLY_ACCESS_KEY=
TENDERLY_ACCOUNT_SLUG=
TENDERLY_PROJECT_SLUG=
TEST_RPC_URL=
DISABLE_STS_CHECKS=false
