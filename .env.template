# ============================================================# Jinn Mech Worker Configuration Template
# ============================================================# This file is for PRODUCTION/MAINNET configuration.
# For testnet/Tenderly VNet testing, see .env.test
#
# Copy this file to .env and fill in your actual values
# See README.md for detailed setup instructions
#
# NOTE: All environment variables are validated at runtime using Zod schemas
# in config/index.ts. Invalid or missing required values will fail fast with
# clear error messages. See docs/spec/code-spec/spec.md for details.

# ============================================================# Core Worker Configuration (REQUIRED)
# ============================================================# Private key for the EOA that provisions the agent's on-chain identity (Gnosis Safe)
WORKER_PRIVATE_KEY=0x...

# Chain ID (8453 = Base mainnet, 84532 = Base Sepolia)
CHAIN_ID=8453

# RPC endpoint for the target blockchain
RPC_URL=https://mainnet.base.org

# ============================================================# Ponder Configuration (REQUIRED for on-chain event indexing)
# ============================================================## GraphQL server port for Ponder (default: 42069)
## This is the single source of truth for the Ponder port across the entire codebase
PONDER_PORT=42069

## Optional: Explicit Ponder GraphQL URL. If unset, code derives
## http://localhost:${PONDER_PORT}/graphql
PONDER_GRAPHQL_URL=

## Frontend convenience (used by dev scripts)
NEXT_PUBLIC_PONDER_PORT=42069

## Optional: Review mode / indexing window tuning
## When set, Ponder starts from this block; otherwise it auto-detects a recent start
PONDER_START_BLOCK=
## Optional: Stop syncing at this block (used for deterministic log review)
PONDER_END_BLOCK=
## Optional: Preserve runtime overrides for Ponder config (used by VNet review/dev flows)
PONDER_REVIEW_MODE=

## Optional: PostgreSQL database for Ponder (enables persistent storage instead of local SQLite)
## Use the same connection string as SUPABASE_POSTGRES_URL or provide a dedicated database
PONDER_DATABASE_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres

# ============================================================# Mech Marketplace Configuration (REQUIRED)
# ============================================================# Address of the MechMarketplace contract on Base
MECH_MARKETPLACE_ADDRESS_BASE=0xf24eE42edA0fc9b33B7D41B06Ee8ccD2Ef7C5020

# ============================================================# Control API Configuration (REQUIRED)
# ============================================================# GraphQL endpoint for Control API (must include /graphql path)
CONTROL_API_URL=http://localhost:4001/graphql
## Server port for Control API (used when running the server locally)
CONTROL_API_PORT=4001

# ============================================================# Supabase Configuration (Optional - for Control API backend)
# ============================================================SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_SERVICE_ANON_KEY=eyJ...

# Postgres direct connection URL (REQUIRED for Ponder node_embeddings indexing)
# Note: SUPABASE_URL above is for REST API, this is for direct DB connection
# Get from: Supabase Dashboard → Settings → Database → Connection string (Direct connection, URI mode)
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres
# Ponder uses this to index SITUATION embeddings into node_embeddings table for vector search
SUPABASE_POSTGRES_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres

# ============================================================# OLAS Middleware Configuration (REQUIRED for service deployment)
# ============================================================# Password for olas-operate-middleware (encrypts wallet keystore)
OPERATE_PASSWORD=your-secure-password

# Middleware operating mode (true = interactive prompts, false = automated)
ATTENDED=true

# Staking program ("no_staking" for testing, "custom_staking" for mainnet)
STAKING_PROGRAM=no_staking

# ============================================================# IPFS Configuration (REQUIRED for request/delivery data)
# ============================================================# IPFS gateway URL for fetching request prompts and uploading results
IPFS_GATEWAY_URL=https://gateway.autonolas.tech/ipfs/

# Timeout for IPFS fetch operations (in milliseconds)
IPFS_FETCH_TIMEOUT_MS=30000

# ============================================================# LLM API Configuration (Optional - for AI-powered job execution)
# ============================================================GEMINI_API_KEY=
OPENAI_API_KEY=
## Default model used by the mech worker (tests/tools may override)
MECH_MODEL=gemini-2.5-flash

# ============================================================# GitHub MCP Server Configuration (REQUIRED for GitHub integration)
# ============================================================# GitHub Personal Access Token for MCP server (requires 'repo' scope)
# Generate at: https://github.com/settings/tokens/new
GITHUB_TOKEN=

# ============================================================# Git Workflow Configuration (Optional - for ventures and code-based jobs)
# ============================================================# Directory where venture repositories are cloned
# When a job includes codeMetadata.repo.remoteUrl, the worker will clone it to:
# ${JINN_WORKSPACE_DIR}/{repo-name}
# Example: git@github.com:user/jinn-marketing.git -> ~/jinn-repos/jinn-marketing
# Defaults to ~/jinn-repos if not set
JINN_WORKSPACE_DIR=~/jinn-repos

# Legacy: Explicit repository root for code metadata operations
# Only needed if not using remote-based cloning (JINN_WORKSPACE_DIR is preferred)
# CODE_METADATA_REPO_ROOT=

# ============================================================# Frontend Explorer (Optional)
# ============================================================## If set, overrides the default Ponder GraphQL URL in the Next.js app
NEXT_PUBLIC_SUBGRAPH_URL=

# ============================================================# Development & Testing Configuration (Optional)
# ============================================================# Node environment (development, production)
NODE_ENV=development

## MCP server log level (error, warn, info, debug). Defaults to 'error'
MCP_LOG_LEVEL=error

# Enable TSX mode for MCP server development
USE_TSX_MCP=1

# Local transaction queue database path
LOCAL_QUEUE_DB_PATH=./data/transaction_queue.db

# Enable transaction executor
ENABLE_TRANSACTION_EXECUTOR=true

# ============================================================# Additional API Keys (Optional)
# ============================================================# Security scanning with Snyk (https://app.snyk.io/account)
SNYK_TOKEN=

# Zora API (https://zora.co/)
ZORA_API_KEY=

# ============================================================
# Blueprint Builder Configuration (Optional)
# ============================================================
# Enable debug logging for blueprint building
BLUEPRINT_BUILDER_DEBUG=false

# Log which providers contribute to each blueprint
BLUEPRINT_LOG_PROVIDERS=false

# Enable/disable specific providers (all true by default)
BLUEPRINT_ENABLE_SYSTEM=true
BLUEPRINT_ENABLE_CONTEXT_ASSERTIONS=true
BLUEPRINT_ENABLE_RECOGNITION=true
BLUEPRINT_ENABLE_JOB_CONTEXT=true
BLUEPRINT_ENABLE_PROGRESS=true
