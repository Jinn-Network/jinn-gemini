# Tenderly Virtual TestNet Configuration
# Copy this to env.tenderly and fill in your credentials

# Enable Tenderly mode (switches from mainnet to virtual testnet)
TENDERLY_ENABLED=true

# Tenderly API credentials
# Get these from: https://dashboard.tenderly.co/account/authorization
TENDERLY_ACCESS_KEY=your-tenderly-access-key-here
TENDERLY_ACCOUNT_SLUG=your-account-slug
TENDERLY_PROJECT_SLUG=your-project-slug

# Virtual TestNet configuration
# Created by running: yarn setup:tenderly-vnet
TENDERLY_VNET_ID=your-vnet-id-will-be-generated
TENDERLY_RPC_URL=https://virtual.base.rpc.tenderly.co/your-vnet-id

# Override BASE_LEDGER_RPC to use Tenderly
BASE_LEDGER_RPC=${TENDERLY_RPC_URL}

# Existing OLAS configuration (keep these)
OPERATE_PASSWORD=your-password
STAKING_PROGRAM=no_staking

# Note: When TENDERLY_ENABLED=true:
# - All transactions go to simulated Base mainnet fork
# - Unlimited ETH available (no real funds needed)
# - Instant transaction confirmation
# - View all transactions in Tenderly dashboard

# To switch back to mainnet:
# 1. Set TENDERLY_ENABLED=false, OR
# 2. Unset all TENDERLY_* variables, OR
# 3. Use regular .env file instead

