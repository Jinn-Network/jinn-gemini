# jinn-node Secrets
# Copy to .env and fill in values. Only secrets belong here.
# Configuration values are in jinn.yaml (auto-generated on first run).

# =============================================================================
# REQUIRED: Secrets
# =============================================================================
RPC_URL=
OPERATE_PASSWORD=

# =============================================================================
# LLM Auth (one of these must be set)
# =============================================================================
# Option A: Gemini CLI login (recommended) — no env var needed.
#   Run: npx @google/gemini-cli auth login
# Option B: API key
# GEMINI_API_KEY=your_gemini_api_key
# Option C: OAuth credentials (advanced, for rotation)
# GEMINI_OAUTH_CREDENTIALS=[{"oauth_creds":{...},"google_accounts":{"active":"you@example.com"}}]

# =============================================================================
# STRONGLY ENCOURAGED (coding jobs)
# =============================================================================
# Without GITHUB_TOKEN, most coding jobs will fail or be skipped.
GITHUB_TOKEN=
GIT_AUTHOR_NAME=
GIT_AUTHOR_EMAIL=

# =============================================================================
# OPTIONAL: Earning Schedule
# =============================================================================
# These can also be set in jinn.yaml under the filtering section.
# Legacy env vars are supported as overrides.
# EARNING_SCHEDULE=22:00-08:00
# EARNING_MAX_JOBS=10
