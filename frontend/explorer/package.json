{
  "name": "explorer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "lsof -ti:${PONDER_PORT:-42069} | xargs kill -9 2>/dev/null || true",
    "dev": "NEXT_PUBLIC_SUBGRAPH_URL=https://jinn-gemini-production.up.railway.app/graphql next dev --turbopack",
    "dev:local": "env NEXT_PUBLIC_SUBGRAPH_URL=${NEXT_PUBLIC_SUBGRAPH_URL:-http://localhost:42069/graphql} next dev --turbopack",
    "dev:with-ponder": "env NEXT_PUBLIC_SUBGRAPH_URL=${NEXT_PUBLIC_SUBGRAPH_URL:-http://localhost:42069/graphql} NEXT_PUBLIC_PONDER_PORT=${PONDER_PORT:-42069} concurrently \"next dev --turbopack\" \"cd ../../ponder && yarn dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "clean": "rm -rf .next out",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@ponder/client": "^0.15.12",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "graphql": "^16.11.0",
    "graphql-request": "^7.2.0",
    "lucide-react": "^0.536.0",
    "next": "15.4.7",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "^10.1.0",
    "reactflow": "^11.11.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "^20",
    "@types/react": "19.2.7",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^9",
    "eslint-config-next": "15.4.5",
    "jsdom": "^23.0.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.6",
    "typescript": "^5",
    "vitest": "^1.1.0"
  }
}
