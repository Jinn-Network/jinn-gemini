{
  "name": "explorer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "lsof -ti:${PONDER_PORT:-42069} | xargs kill -9 2>/dev/null || true",
    "dev": "NEXT_PUBLIC_SUBGRAPH_URL=https://ponder-production-6d16.up.railway.app/graphql NEXT_PUBLIC_X402_GATEWAY_URL=https://x402-gateway-production.up.railway.app next dev --turbopack",
    "dev:local": "env NEXT_PUBLIC_SUBGRAPH_URL=${NEXT_PUBLIC_SUBGRAPH_URL:-http://localhost:42069/graphql} next dev --turbopack",
    "dev:with-ponder": "env NEXT_PUBLIC_SUBGRAPH_URL=${NEXT_PUBLIC_SUBGRAPH_URL:-http://localhost:42069/graphql} NEXT_PUBLIC_PONDER_PORT=${PONDER_PORT:-42069} concurrently \"next dev --turbopack\" \"cd ../../ponder && yarn dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "clean": "rm -rf .next out",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@jinn/shared-ui": "*",
    "@ponder/client": "^0.15.16",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cron-parser": "^5.0.0",
    "drizzle-orm": "^0.44.7",
    "graphql": "^16.11.0",
    "graphql-request": "^7.2.0",
    "lucide-react": "^0.560.0",
    "next": "^16.0.7",
    "next-themes": "^0.4.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "^10.1.0",
    "reactflow": "^11.11.4",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "viem": "^2.35.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@storybook/nextjs": "^10",
    "@storybook/react": "^10",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "^20",
    "@types/react": "19.2.7",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^9",
    "eslint-config-next": "15.4.5",
    "jsdom": "^23.0.1",
    "storybook": "^10",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.6",
    "typescript": "^5",
    "vitest": "^1.1.0"
  }
}
