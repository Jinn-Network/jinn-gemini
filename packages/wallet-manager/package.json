{
  "name": "@jinn/wallet-manager",
  "version": "2.0.0",
  "description": "Gnosis Safe wallet bootstrapping and identity management for Jinn workers",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "type-check": "tsc --noEmit",
    "prepack": "yarn clean && yarn build"
  },
  "keywords": [
    "gnosis-safe",
    "wallet",
    "ethereum",
    "olas",
    "identity",
    "multisig"
  ],
  "author": "Jinn Project",
  "license": "MIT",
  "dependencies": {
    "@safe-global/protocol-kit": "^6.1.0",
    "@safe-global/safe-core-sdk-types": "^5.1.0",
    "@safe-global/types-kit": "^3.0.0",
    "viem": "2.35.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "20.17.9",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint": "8.57.1",
    "jest": "^30.0.5",
    "ts-jest": "^29.4.1",
    "typescript": "5.9.2"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jinn-project/jinn-cli-agents.git",
    "directory": "packages/wallet-manager"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
