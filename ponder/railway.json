{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "concurrently \"ponder start\" \"tsx realtime-server.ts\" --names \"ponder,realtime\" --prefix-colors \"cyan,magenta\"",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}

