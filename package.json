{
  "name": "gemini-cli-jinn",
  "version": "1.0.0",
  "private": true,
  "description": "Gemini CLI Jinn worker system",
  "type": "module",
  "main": "dist/worker.js",
  "scripts": {
    "build": "tsc -p .",
    "start": "node dist/worker/worker.js",
    "dev": "tsx watch worker/worker.ts",
    "dev:continuous": "USE_TSX_MCP=1 tsx worker/worker.ts",
    "dev:job": "USE_TSX_MCP=1 tsx worker/worker.ts -- --job-id",
    "start:job": "node dist/worker/worker.js -- --job-id",
    "test": "vitest",
    "test:integration": "vitest run gemini-agent/mcp/tools.integration.test.ts",
    "test:e2e": "tsx scripts/e2e-test-rig.ts",
    "test:e2e:dual-rail": "tsx scripts/dual-rail-e2e-test.ts",
    "test:e2e:zora": "tsx scripts/zora-dual-rail-e2e-test.ts",
    "frontend:dev": "cd frontend/explorer && yarn run dev",
    "frontend:start": "cd frontend/explorer && yarn run start",
    "frontend:build": "cd frontend/explorer && yarn run build",
    "dev:all": "run-p dev mcp:start",
    "start:all": "concurrently \"yarn start\" \"yarn frontend:start\" --names \"worker,frontend\" --prefix-colors \"blue,green\"",
    "clean": "rimraf dist",
    "mcp:start": "tsx --env-file=.env gemini-agent/mcp/server.ts",
    "wallet:set-creator-coin": "cd packages/wallet-manager && yarn build && yarn set-creator-coin",
    "test:zora-unit": "jest --testPathPatterns=zora",
    "test:zora-e2e": "tsx scripts/zora-e2e-test.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@jinn/wallet-manager": "file:packages/wallet-manager",
    "@modelcontextprotocol/sdk": "^1.11.0",
    "@safe-global/protocol-kit": "^6.1.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.53.0",
    "@zoralabs/coins-sdk": "^0.3.0",
    "cross-fetch": "^4.1.0",
    "dotenv": "^17.2.1",
    "ethers": "^5.7.2",
    "openai": "^5.11.0",
    "pino": "^9.9.0",
    "pino-pretty": "^13.1.1",
    "yargs": "^18.0.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/yargs": "^17.0.33",
    "concurrently": "^8.2.2",
    "execa": "^9.6.0",
    "jest": "^30.0.5",
    "ts-jest": "^29.4.1",
    "tsx": "^4.20.5",
    "typescript": "^5.0.0",
    "viem": "^2.35.1",
    "vitest": "^3.2.4"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
