{
  "name": "gemini-cli-jinn",
  "version": "1.0.0",
  "private": true,
  "description": "Gemini CLI Jinn worker system",
  "type": "module",
  "workspaces": [
    "packages/*",
    "frontend/*"
  ],
  "main": "dist/worker.js",
  "scripts": {
    "start": "cd jinn-node && . scripts/init.sh && node dist/worker/worker_launcher.js",
    "build": "cd jinn-node && yarn build",
    "dev:mech": "cd jinn-node && yarn run worker",
    "dev:mech:parallel": "tsx scripts/dev-mech-parallel.ts",
    "worker:start": "cd jinn-node && node dist/worker/mech_worker.js",
    "ponder:predev": "node ponder/scripts/set-start-block.js && node -e \"try{require('better-sqlite3');console.log('better-sqlite3 ok')}catch(e){process.exitCode=0}\" || npm rebuild better-sqlite3",
    "ponder:dev": "yarn ponder:predev && cd ponder && ponder dev --port ${PONDER_PORT:-42069}",
    "ponder:build": "cd ponder && ponder build",
    "ponder:start": "cd ponder && ponder start",
    "ponder": "yarn ponder:dev",
    "dev:stack": "concurrently \"yarn ponder:dev\" \"yarn control:dev\" \"yarn frontend:dev\" --names \"ponder,control,frontend\" --prefix-colors \"cyan,magenta,green\"",
    "dev:local-stack": "sh -c 'tsx scripts/local-dev-stack.ts \"$@\"' --",
    "dev:stack:direct": "concurrently \"cd ponder && yarn dev\" \"yarn control:dev\" \"yarn frontend:dev\" --names \"ponder,control,frontend\" --prefix-colors \"cyan,magenta,green\"",
    "control-api": "tsx control-api/server.ts",
    "frontend-explorer": "cd frontend/explorer && yarn dev",
    "frontend-explorer:storybook": "cd frontend/explorer && yarn storybook",
    "control:dev": "tsx control-api/server.ts",
    "test:onchain:e2e": "tsx scripts/test_onchain_e2e.ts",
    "test": "vitest",
    "test:unit": "vitest --run",
    "test:marketplace": "vitest run --project marketplace",
    "test:worker": "vitest run --project worker",
    "test:git": "vitest run --project git",
    "test:service": "vitest run --project service",
    "test:codespec": "vitest run --project codespec",
    "test:integration": "vitest run --project integration",
    "test:parallel": "vitest run --project marketplace & vitest run --project worker & wait",
    "test:all": "yarn test:marketplace && yarn test:worker && yarn test:service",
    "test:e2e": "yarn test:e2e:legacy && yarn test:e2e:vitest",
    "test:e2e:legacy": "tsx scripts/e2e-test-rig.ts",
    "test:e2e:vitest": "vitest run --project e2e",
    "test:e2e:dual-rail": "tsx scripts/dual-rail-e2e-test.ts",
    "test:e2e:zora": "tsx scripts/zora-dual-rail-e2e-test.ts",
    "test:e2e:bootstrap": "sh -c 'tsx scripts/test/e2e-bootstrap.ts \"$@\"' --",
    "test:e2e:vnet": "sh -c 'tsx scripts/test/e2e-harness.ts \"$@\"' --",
    "test:e2e:dispatch": "sh -c 'tsx scripts/test/dispatch-workstream-job.ts \"$@\"' --",
    "test:e2e:clone": "sh -c 'tsx scripts/test/setup-clone.ts \"$@\"' --",
    "test:e2e:stack": "sh -c 'tsx scripts/test/start-e2e-stack.ts \"$@\"' --",
    "test:e2e:docker-run": "sh -c 'tsx scripts/test/docker-run.ts \"$@\"' --",
    "test:e2e:permissions": "sh -c 'tsx scripts/test/credential-permission-matrix.ts \"$@\"' --",
    "test:e2e:parse-telemetry": "sh -c 'tsx scripts/test/parse-telemetry.ts \"$@\"' --",
    "test:railway:canary": "sh -c 'tsx scripts/test/railway/canary-harness.ts \"$@\"' --",
    "test:railway:canary:pre-smoke": "yarn test:railway:canary -- --session pre-smoke",
    "test:railway:canary:smoke": "yarn test:railway:canary -- --session smoke",
    "test:pipeline:inspect": "sh -c 'tsx scripts/test/pipeline/inspect-gates.ts \"$@\"' --",
    "test:pipeline:canary:create": "sh -c 'tsx scripts/test/pipeline/ephemeral-canary.ts create \"$@\"' --",
    "test:pipeline:canary:teardown": "sh -c 'tsx scripts/test/pipeline/ephemeral-canary.ts teardown \"$@\"' --",
    "test:pipeline:canary:cleanup": "sh -c 'tsx scripts/test/pipeline/ephemeral-canary.ts cleanup \"$@\"' --",
    "test:worker-e2e": "tsx scripts/test-worker-e2e.ts",
    "test:jinn-198": "tsx scripts/jinn-198-mech-deployment-test.ts",
    "test:tenderly": "tsx scripts/test-on-tenderly.ts",
    "cleanup:tenderly": "tsx scripts/cleanup-tenderly-vnets.ts",
    "deploy:service-with-mech": "tsx scripts/deploy-service-with-mech.ts",
    "test:marketplace-dispatch": "tsx scripts/test-marketplace-dispatch.ts",
    "test:dispatch-mcp": "tsx scripts/test-dispatch-mcp-tool.ts",
    "test:dispatch-existing-def": "tsx scripts/test-reproduce-dispatch-issue.ts",
    "test:dispatch-errors": "tsx scripts/test-dispatch-error-handling.ts",
    "frontend:dev": "cd frontend/explorer && yarn run dev:local",
    "frontend:start": "cd frontend/explorer && yarn run start",
    "frontend:build": "cd frontend/explorer && yarn run build",
    "frontend:spec": "cd frontend/spec && yarn start",
    "dev:all": "yarn dev:mech",
    "start:all": "concurrently \"yarn mech\" \"yarn frontend:start\" --names \"worker,frontend\" --prefix-colors \"blue,green\"",
    "clean": "rm -rf dist && cd frontend/explorer && yarn run clean",
    "skills:sync": "tsx scripts/sync-skills.ts",
    "skills:copy": "tsx scripts/sync-skills.ts --copy",
    "hooks:install": "cp hooks/* .git/hooks/ && chmod +x .git/hooks/*",
    "test:zora-e2e": "tsx scripts/zora-e2e-test.ts",
    "test:unit:next": "vitest run --config vitest.config.next.ts tests-next/unit",
    "test:integration:next": "vitest run --config vitest.config.next.ts tests-next/integration",
    "test:system:next": "vitest run --config vitest.config.next.ts tests-next/system",
    "test:next": "yarn test:unit:next && yarn test:integration:next && yarn test:system:next",
    "lint": "eslint .",
    "format": "prettier --write .",
    "lint:fix": "eslint . --fix",
    "civitai:debug": "tsx scripts/civitai-sdk-debug.ts",
    "civitai:post-intent-debug": "tsx scripts/civitai-post-intent-debug.ts",
    "deliver:request": "tsx scripts/deliver_request.ts",
    "dev:vnet": "tsx scripts/dev-vnet.ts",
    "cleanup:vnet": "tsx scripts/cleanup-vnet.ts",
    "cleanup:workers": "tsx scripts/cleanup-workers.ts",
    "review:vnet": "tsx scripts/review-vnet.ts",
    "list:archives": "tsx scripts/list-archives.ts",
    "security:check": "snyk test --all-projects --severity-threshold=high",
    "security:monitor": "snyk monitor --all-projects",
    "security:fix": "snyk wizard",
    "setup:dev": "bash scripts/dev-setup.sh",
    "setup:python": "bash scripts/dev-setup.sh --python-only",
    "setup:service": "tsx scripts/interactive-service-setup.ts",
    "subtree:setup": "bash scripts/subtree.sh setup",
    "subtree:push": "bash scripts/subtree.sh push",
    "subtree:pull": "bash scripts/subtree.sh pull",
    "subtree:status": "bash scripts/subtree.sh status",
    "restake:service": "cd jinn-node && poetry run python -m operate.quickstart.run_service",
    "qa:jinn-179": "bash scripts/qa-jinn-179.sh",
    "inspect-job-run": "tsx scripts/inspect-job-run.ts",
    "mech:check-rate": "tsx scripts/mech/check-max-delivery-rate.ts",
    "mech:set-rate": "tsx scripts/mech/set-max-delivery-rate.ts",
    "mech:update-rate": "tsx scripts/mech/update-max-delivery-rate.ts",
    "inspect-job": "tsx scripts/inspect-job.ts",
    "inspect-workstream": "tsx scripts/inspect-workstream.ts",
    "test:inspection-tools": "tsx scripts/test-inspection-tools.ts",
    "launch:workstream": "sh -c 'tsx scripts/launch_workstream.ts \"$@\" | tsx logging/dev-pretty-cli.ts' --",
    "launch:template": "sh -c 'tsx scripts/launch-local-template.ts \"$@\" | tsx logging/dev-pretty-cli.ts' --",
    "x402:build": "sh -c 'tsx scripts/x402-build.ts \"$@\" | tsx logging/dev-pretty-cli.ts' --",
    "x402:execute": "sh -c 'tsx scripts/x402-execute-template.ts \"$@\" | tsx logging/dev-pretty-cli.ts' --",
    "dispatch-paid-template": "sh -c 'tsx scripts/dispatch-paid-template.ts \"$@\" | tsx logging/dev-pretty-cli.ts' --",
    "codespec:review": "./codespec/scripts/review.sh",
    "codespec:render": "tsx codespec/scripts/render-spec.ts",
    "provision": "tsx scripts/product/provision.ts",
    "postinstall": "cd jinn-node && yarn install",
    "olas:dashboard": "tsx scripts/olas/dashboard.ts",
    "olas:economics": "tsx scripts/olas/economics.ts"
  },
  "dependencies": {
    "@jinn-network/mech-client-ts": "^0.0.6",
    "@modelcontextprotocol/sdk": "^1.11.0",
    "@octokit/rest": "^22.0.1",
    "@safe-global/protocol-kit": "^6.1.0",
    "@slicekit/erc8128": "^0.1.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.53.0",
    "@whetstone-research/doppler-sdk": "^0.0.17",
    "@zoralabs/coins-sdk": "^0.3.0",
    "better-sqlite3": "^12.4.1",
    "civitai": "^0.1.15",
    "cross-fetch": "^4.1.0",
    "dotenv": "^17.2.2",
    "ethers": "^6.15.0",
    "graphql-request": "^7.2.0",
    "graphql-yoga": "^5.15.2",
    "@coinbase/x402": "^1.0.0",
    "@hono/node-server": "^1.19.7",
    "hono": "^4.10.7",
    "ioredis": "^5.9.2",
    "openai": "^5.11.0",
    "pg": "^8.12.0",
    "pino": "^9.9.0",
    "pino-pretty": "^13.1.1",
    "ponder": "^0.15.16",
    "x402-fetch": "^1.0.0",
    "x402-hono": "^1.0.0",
    "yargs": "^17.7.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@google/gemini-cli": "^0.25.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.16.0",
    "@types/yargs": "^17.0.33",
    "better-sqlite3": "^12.4.1",
    "concurrently": "^8.2.2",
    "execa": "^9.6.0",
    "playwright": "^1.55.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.0.0",
    "viem": "^2.35.1",
    "vitest": "^2.1.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "resolutions": {
    "nanoid": "^5.0.9",
    "parse-duration": "^2.1.3"
  },
  "overrides": {
    "@google/genai": "^1.22.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "volta": {
    "node": "22.11.0",
    "yarn": "1.22.22"
  }
}
