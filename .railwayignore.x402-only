# Railway upload exclusions — primarily used for x402-gateway deploys via `railway up`.
# The worker service deploys via GitHub trigger and does NOT use this file.
# Large non-essential directories - exclude to reduce upload size
code-resources/
frontend/
services/*
!services/x402-gateway
contracts/
logs/
tests-next/
service-backups/
olas-operate-middleware/
skills/
ponder/
control-api/
worker/
gemini-agent/
migrations/
configs/

# Development/docs directories
docs/
blueprints/
codespec/
tests/

# Build artifacts not needed at deploy time
jinn-node/dist/

# OLAS operate local data (secrets) - only exclude root .operate
# Keep olas-operate-middleware/.operate/ for middleware functionality
.operate/

# Markdown files except README
*.md
!README.md

# Environment files - prevent dotenv overriding Railway env vars
.env
.env.*
!.env.template

# Git, IDE, and tooling artifacts
.git/
.vscode/
.idea/
.conductor/
.playwright-mcp/
.cursor/
.beads/
packages/
