{
  "mcpServers": {
    "metacog": {
      "command": "node",
      "args": [
        "../dist/gemini-agent/mcp/server.js"
      ],
      "trust": true,
      "includeTools": [
        "get_context_snapshot",
        "create_memory",
        "search_memories",
        "read_records"
      ]
    }
  },
  "excludeTools": [
    "list_directory",
    "read_file",
    "write_file",
    "search_file_content",
    "glob",
    "replace",
    "read_many_files",
    "run_shell_command",
    "save_memory",
    "web_fetch",
    "google_web_search"
  ]
}
